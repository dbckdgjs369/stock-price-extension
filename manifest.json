{
  "manifest_version": 3,
  "name": "Stock Price Widget",
  "version": "3.0.0",
  "description": "웹페이지 위에 여러 주식 시세 위젯을 배치합니다",
  "permissions": ["storage", "alarms", "tabs", "scripting"],
  "host_permissions": [
    "https://query1.finance.yahoo.com/*",
    "https://query2.finance.yahoo.com/*",
    "https://api.gateio.ws/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
